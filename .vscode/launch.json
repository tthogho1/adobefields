{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File (Integrated Terminal)",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Module (adobesign_client)",
      "type": "python",
      "request": "launch",
      "module": "adobesign_client",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Attach (5678)",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      }
    }
    ,
    {
      "name": "Python: adobe_sign_field_updater (fields.txt)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/adobe_sign_field_updater.py",
      "args": [
        "CBJCHBCAABAAj4RkpThC5mQH4JLjKWV1bapAV7wsw1jd",
        "fields.txt"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
