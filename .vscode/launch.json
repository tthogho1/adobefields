{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File (Integrated Terminal)",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Module (adobesign_client)",
      "type": "python",
      "request": "launch",
      "module": "adobesign_client",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Attach (5678)",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      }
    }
  ]
}
